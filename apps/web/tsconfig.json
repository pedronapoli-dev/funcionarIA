{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target":           "ES2017",
    "lib":              ["dom", "dom.iterable", "esnext"],
    "module":           "esnext",
    "moduleResolution": "bundler",
    "allowJs":          true,
    "jsx":              "preserve",
    "incremental":      true,
    "plugins":          [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "references": [
    { "path": "../../packages/types" }
  ],
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
