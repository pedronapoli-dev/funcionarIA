{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target":           "ES2017",
    "lib":              ["dom", "dom.iterable", "esnext"],
    "module":           "esnext",
    "moduleResolution": "bundler",
    "allowJs":          true,
    "jsx":              "preserve",
    "incremental":      true,
    "plugins":          [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@educarseia/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/types" }
  ]
}
