{
  "name": "funcionaria",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev":        "turbo run dev",
    "build":      "turbo run build",
    "lint":       "turbo run lint",
    "type-check": "turbo run type-check",
    "clean":      "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo":      "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.5.0"
}
